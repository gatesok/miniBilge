FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

COPY MiniBilge.sln .
COPY MiniBilge.API/MiniBilge.API.csproj MiniBilge.API/
COPY MiniBilge.Application/MiniBilge.Application.csproj MiniBilge.Application/
COPY MiniBilge.Domain/MiniBilge.Domain.csproj MiniBilge.Domain/
COPY MiniBilge.Infrastructure/MiniBilge.Infrastructure.csproj MiniBilge.Infrastructure/
COPY MiniBilge.Shared/MiniBilge.Shared.csproj MiniBilge.Shared/
COPY MiniBilge.Tests/MiniBilge.Tests.csproj MiniBilge.Tests/

RUN dotnet restore

COPY . .

RUN dotnet publish MiniBilge.API/MiniBilge.API.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app

COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
ENV ASPNETCORE_ENVIRONMENT=Production

EXPOSE 8080

ENTRYPOINT ["dotnet", "MiniBilge.API.dll"]
