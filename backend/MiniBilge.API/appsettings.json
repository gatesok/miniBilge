{
  "DatabaseProvider": "PostgreSQL",
  "ConnectionStrings": {
    "SQLite": "Data Source=minibilge.db",
    "PostgreSQL": ""
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "MiniBilge.API",
    "Audience": "MiniBilge.Client",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "FromEmail": "minibilgeapp@gmail.com",
    "AppPassword": ""
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

