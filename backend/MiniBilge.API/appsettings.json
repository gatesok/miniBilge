{
  "DatabaseProvider": "PostgreSQL",
  "ConnectionStrings": {
    "SQLite": "Data Source=minibilge.db",
    "PostgreSQL": "Host=localhost;Port=5432;Database=minibilge_db;Username=minibilge_user;Password=REDACTED_DEV_PASSWORD"
  },
  "JwtSettings": {
    "SecretKey": "REDACTED_JWT_KEY",
    "Issuer": "MiniBilge.API",
    "Audience": "MiniBilge.Client",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

